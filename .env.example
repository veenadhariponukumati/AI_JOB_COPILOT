# AI Job Copilot - Environment Variables
# Copy this file to .env and fill in your values

# Application
APP_NAME=AI Job Copilot
APP_VERSION=2.0.0
DEBUG=false

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_job_copilot

# OpenAI API
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# RAG Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=5
SIMILARITY_THRESHOLD=0.7

# Scoring Weights (must sum to 1.0)
KEYWORD_WEIGHT=0.4
SEMANTIC_WEIGHT=0.4
CATEGORY_WEIGHT=0.2

# Caching
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# Skill Extraction
SKILL_CONFIDENCE_THRESHOLD=0.6
MAX_SKILLS_PER_DOCUMENT=50

# Clerk Auth
CLERK_FRONTEND_API=your-app.clerk.accounts.dev
CLERK_SECRET_KEY=sk_live_xxx-or-sk_test_xxx

# Email (Resend) - used to notify the site owner of new feedback
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=onboarding@resend.dev
FEEDBACK_NOTIFY_EMAIL=your-email@example.com
